{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--browser", "chromium",
        "--caps", "vision,devtools",
        "--console-level", "error",
        "--codegen", "typescript",
        "--output-dir", "./playwright-output"
      ]
    }
  }
}
